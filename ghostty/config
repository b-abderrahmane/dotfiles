# ---- Clipboard ----
# valid: allow | deny | ask
clipboard-read = allow
clipboard-write = allow

# valid: false | true | clipboard
copy-on-select = clipboard

# ---- Fonts (optional) ----
font-family = "JetBrainsMono Nerd Font"
font-size = 13.0

# ---- Shell ----

# ---- Keybinds ----

# --- Ensure Linux-style control key passthroughs ---
#keybind = ctrl+c=unbind
#keybind = ctrl+v=unbind
#keybind = ctrl+r=unbind
#keybind = ctrl+a=unbind
#keybind = ctrl+e=unbind

# FORMAT A (preferred): keybind = <shortcut> <action>
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+t=new_tab

